<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/cartTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/cart_title"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/headerDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="32dp"
        android:background="@color/divider"
        app:layout_constraintTop_toBottomOf="@id/cartTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/cartScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/headerDivider"
        app:layout_constraintBottom_toTopOf="@id/checkoutButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Contenedor de los items -->
        <LinearLayout
            android:id="@+id/cartItemsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <!-- Producto/item pimiento rojo -->
            <LinearLayout
                android:id="@+id/redPepperItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/redPepperImage"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:src="@drawable/img_red_pepper"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/product_red_pepper" />

                <!-- Información del producto/item -->
                <LinearLayout
                    android:id="@+id/redPepperInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:id="@+id/redPepperName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/product_red_pepper"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/redPepperUnit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/unit_red_pepper"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp" />

                    <!-- Aumentar y disminuir cantidad de producto -->
                    <LinearLayout
                        android:id="@+id/redPepperQuantityContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <Button
                            android:id="@+id/redPepperMinusButton"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:padding="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="-"
                            android:textSize="24sp"
                            android:textAllCaps="false"
                            android:textColor="@color/remove_icon"
                            android:backgroundTint="@color/background" />

                        <TextView
                            android:id="@+id/redPepperQuantity"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/redPepperPlusButton"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:padding="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="+"
                            android:textSize="24sp"
                            android:textAllCaps="false"
                            android:textColor="@color/primary_green"
                            android:backgroundTint="@color/background" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Eliminar item + precio -->
                <LinearLayout
                    android:id="@+id/redPepperActionsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <Button
                        android:id="@+id/redPepperRemoveButton"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:translationY="-6dp"
                        android:text="×"
                        android:textSize="24sp"
                        android:textAllCaps="false"
                        android:textColor="@color/remove_icon"
                        android:backgroundTint="@color/background" />

                    <TextView
                        android:id="@+id/redPepperPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="@string/price_red_pepper"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <View
                android:id="@+id/redPepperDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />

            <!-- Producto/item huevos -->
            <LinearLayout
                android:id="@+id/eggsItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/eggsImage"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:src="@drawable/img_eggs"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/product_eggs" />

                <!-- Información del producto/item -->
                <LinearLayout
                    android:id="@+id/eggsInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:id="@+id/eggsName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/product_eggs"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/eggsUnit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/unit_eggs"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp" />

                    <!-- Aumentar y disminuir cantidad de producto -->
                    <LinearLayout
                        android:id="@+id/eggsQuantityContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <Button
                            android:id="@+id/eggsMinusButton"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:padding="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="-"
                            android:textSize="24sp"
                            android:textAllCaps="false"
                            android:textColor="@color/remove_icon"
                            android:backgroundTint="@color/background" />

                        <TextView
                            android:id="@+id/eggsQuantity"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/eggsPlusButton"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:padding="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="+"
                            android:textSize="24sp"
                            android:textAllCaps="false"
                            android:textColor="@color/primary_green"
                            android:backgroundTint="@color/background" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Eliminar item + precio -->
                <LinearLayout
                    android:id="@+id/eggsActionsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <Button
                        android:id="@+id/eggsRemoveButton"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:translationY="-6dp"
                        android:text="×"
                        android:textSize="24sp"
                        android:textAllCaps="false"
                        android:textColor="@color/remove_icon"
                        android:backgroundTint="@color/background" />

                    <TextView
                        android:id="@+id/eggsPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="@string/price_eggs"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <View
                android:id="@+id/eggsDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />

            <!-- Producto/item bananas -->
            <LinearLayout
                android:id="@+id/bananasItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/bananasImage"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:src="@drawable/img_bananas"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/product_bananas" />

                <!-- Información del producto/item -->
                <LinearLayout
                    android:id="@+id/bananasInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:id="@+id/bananasName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/product_bananas"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/bananasUnit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/unit_bananas"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp" />

                    <!-- Aumentar y disminuir cantidad de producto -->
                    <LinearLayout
                        android:id="@+id/bananasQuantityContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <Button
                            android:id="@+id/bananasMinusButton"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:padding="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="-"
                            android:textSize="24sp"
                            android:textAllCaps="false"
                            android:textColor="@color/remove_icon"
                            android:backgroundTint="@color/background" />

                        <TextView
                            android:id="@+id/bananasQuantity"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/bananasPlusButton"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:padding="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="+"
                            android:textSize="24sp"
                            android:textAllCaps="false"
                            android:textColor="@color/primary_green"
                            android:backgroundTint="@color/background" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Eliminar item + precio -->
                <LinearLayout
                    android:id="@+id/bananasActionsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <Button
                        android:id="@+id/bananasRemoveButton"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:translationY="-6dp"
                        android:text="×"
                        android:textSize="24sp"
                        android:textAllCaps="false"
                        android:textColor="@color/remove_icon"
                        android:backgroundTint="@color/background" />

                    <TextView
                        android:id="@+id/bananasPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="@string/price_bananas"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <View
                android:id="@+id/bananasDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />

            <!-- Producto/item jengibre -->
            <LinearLayout
                android:id="@+id/gingerItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/gingerImage"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:src="@drawable/img_ginger"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/product_ginger" />

                <!-- Información del producto/item -->
                <LinearLayout
                    android:id="@+id/gingerInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:id="@+id/gingerName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/product_ginger"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/gingerUnit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/unit_ginger"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp" />

                    <!-- Aumentar y disminuir cantidad de producto -->
                    <LinearLayout
                        android:id="@+id/gingerQuantityContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <Button
                            android:id="@+id/gingerMinusButton"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:padding="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="-"
                            android:textSize="24sp"
                            android:textAllCaps="false"
                            android:textColor="@color/remove_icon"
                            android:backgroundTint="@color/background" />

                        <TextView
                            android:id="@+id/gingerQuantity"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/gingerPlusButton"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:padding="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="+"
                            android:textSize="24sp"
                            android:textAllCaps="false"
                            android:textColor="@color/primary_green"
                            android:backgroundTint="@color/background" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Eliminar item + precio -->
                <LinearLayout
                    android:id="@+id/gingerActionsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <Button
                        android:id="@+id/gingerRemoveButton"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:translationY="-6dp"
                        android:text="×"
                        android:textSize="24sp"
                        android:textAllCaps="false"
                        android:textColor="@color/remove_icon"
                        android:backgroundTint="@color/background" />

                    <TextView
                        android:id="@+id/gingerPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="@string/price_ginger"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <View
                android:id="@+id/gingerDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />

            <TextView
                android:id="@+id/emptyCartMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:text="@string/cart_empty_message"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:visibility="gone" />

        </LinearLayout>

    </ScrollView>

    <Button
        android:id="@+id/checkoutButton"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="16dp"
        android:text="@string/checkout_button"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:backgroundTint="@color/primary_green"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Navegación -->
    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="88dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="@color/background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Tienda -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_store"
                app:tint="@color/text_primary"
                android:contentDescription="@string/nav_shop" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/nav_shop"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Explorar -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_search"
                app:tint="@color/text_primary"
                android:contentDescription="@string/nav_explore" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/nav_explore"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Carrito seleccionado -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_cart"
                app:tint="@color/primary_green"
                android:contentDescription="@string/nav_cart" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/nav_cart"
                android:textColor="@color/primary_green"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Favoritos -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_favorite"
                app:tint="@color/text_primary"
                android:contentDescription="@string/nav_favorites" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/nav_favorites"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Cuenta -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_user"
                app:tint="@color/text_primary"
                android:contentDescription="@string/nav_account" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/nav_account"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>